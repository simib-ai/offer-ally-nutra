# URL must be the Supabase project where Edge Function `submit-quote` is deployed.
# If the URL points to another project, the browser often shows only "Failed to fetch" (preflight 404).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Edge Function secrets (Dashboard → Project Settings → Edge Functions, or `supabase secrets set` — not Vite):
# RECAPTCHA_SECRET_KEY=required
# If public.leads is on a different Supabase project than the LP: MAIN_SUPABASE_URL + MAIN_SUPABASE_SERVICE_ROLE_KEY
